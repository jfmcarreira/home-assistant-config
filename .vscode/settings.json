{
  "files.associations": {
    "*.yaml": "home-assistant",
    "**/esphome/**/*.yml": "esphome",
    "**/esphome/**/*.yaml": "esphome"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.customTags": [
    "!input"
  ],
  "editor.formatOnSave": false,
  "clangd.arguments": [
    "--query-driver=/Users/joaocarreira/.platformio/packages/toolchain-*/bin/*",
    "-compile-commands-dir=${workspaceFolder}/esphome/.esphome/build/nodemcu_gate/"
  ]
}